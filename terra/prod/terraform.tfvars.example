# ──────────────────────────────────
# General
# ──────────────────────────────────
project_prefix = "leads"
aws_region     = "us-west-2"

# ──────────────────────────────────
# Networking
# ──────────────────────────────────
vpc_cidr            = "10.0.0.0/16"
cidr_public_subnet  = ["10.0.1.0/24", "10.0.3.0/24"]
cidr_private_subnet = "10.0.2.0/24"
availability_zones  = ["us-west-2a", "us-west-2b"]

# ──────────────────────────────────
# SSH Key (existing)
# ──────────────────────────────────
key_name = "batman"

# ──────────────────────────────────
# Database EC2
# ──────────────────────────────────
db_instance_type = "t3.xlarge"
db_private_ip    = "10.0.2.10"

# ──────────────────────────────────
# Database Credentials (sensitive — fill before running)
# ──────────────────────────────────
db_name     = "<your_db_name>"
db_username = "<your_db_user>"
db_password = "<your_db_password>"
es_username = "elastic"
es_password = "<your_es_password>"

# ──────────────────────────────────
# Application
# ──────────────────────────────────
docker_image = "<your_ecr_account_id>.dkr.ecr.us-west-2.amazonaws.com/leads-a2c:latest"

# ──────────────────────────────────
# EKS
# ──────────────────────────────────
eks_cluster_name       = "leads-cluster"
eks_cluster_version    = "1.31"
eks_node_instance_type = "t3.medium"
